# 番小星机器人配置示例
# 复制此文件为 .env 或直接修改 src/index.js 中的 CONFIG

# ===== 必填配置 =====

# 智谱AI API Key (https://open.bigmodel.cn)
GLM_API_KEY=your_glm_api_key_here

# 你的QQ号
QQ_NUMBER=your_qq_number

# 管理员验证码
ADMIN_VERIFY_CODE=your_secret_code

# ===== 可选配置 =====

# 验证命令 (默认 /verify)
ADMIN_VERIFY_CMD=/verify

# ===== Cloudflare Workers 部署 =====
# 使用 wrangler 部署:
# 1. npm install
# 2. 修改 wrangler.toml 中的 KV ID
# 3. npm run deploy
